# If you come from bash you might have to change your $PATH.
export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$PATH

# Add Home Manager user profile to PATH
export PATH="$HOME/.nix-profile/bin:$PATH"

if [[ -f "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh" ]]; then
  source "$HOME/.nix-profile/etc/profile.d/hm-session-vars.sh"
fi

ZSH_THEME="agnoster"
LANG=en_US.UTF-8
export LC_ALL=en_US.UTF-8

# Theme - Start Command Prompt on a new line
prompt_end() {
  if [[ -n $CURRENT_BG ]]; then
      print -n "%{%k%F{$CURRENT_BG}%}$SEGMENT_SEPARATOR"
  else
      print -n "%{%k%}"
  fi

  print -n "%{%f%}"
  CURRENT_BG='' 

  #Adds the new line and ➜ as the start character.
  printf "\n ➜";
}

# FZF
source <(fzf --zsh)
export FZF_BASE="$(which fzf)"
# export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --no-ignore-vcs -g "!{.git,node_modules}/*"'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'
export FZF_TMUX_OPTS=" -p90%,70% "

# Zoxide
eval "$(zoxide init zsh)"

# Alias 
# For a full list of active aliases, run `alias`.
alias ls="ls --color=auto"
alias vim="nvim"
alias zshconfig="nvim ~/.zshrc"
alias k="kubectl"

# fcd - find directory
alias fcd='cd "$(find . -type d | fzf)"'

# Lazygit - 'q' to quit at selected directory, 'shift-q' to quit normally
lg()
{
    export LAZYGIT_NEW_DIR_FILE=~/.lazygit/newdir

    lazygit "$@"

    if [ -f $LAZYGIT_NEW_DIR_FILE ]; then
            cd "$(cat $LAZYGIT_NEW_DIR_FILE)"
            rm -f $LAZYGIT_NEW_DIR_FILE > /dev/null
    fi
}

# direnv
eval "$(direnv hook zsh)"

# Devpod - up
dpup() {
  local devcontainer_path="${1:-./.devcontainer/.devcontainer.json}"
  local workspace_dir="${2:-.}"

  devpod up \
    --dotfiles "https://github.com/leehosanganson/dotfiles" \
    --dotfiles-script=setup.sh \
    --workspace-env-file=.devcontainer/.env \
    --open-ide=0 \
    --devcontainer-path "$devcontainer_path" \
    "$workspace_dir"
}

# Kubernetes
if [ -x "$(command -v kubectl)" ]; then
  source <(kubectl completion zsh)
fi
