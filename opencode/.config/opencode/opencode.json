{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["rules/AGENTS.md", "rules/bash-tool-usage.md"],
  "default_agent": "architect",
  "model": "litellm/unsloth/qwen-3.6",
  "small_model": "litellm/unsloth/qwen-3.6",
  "permission": {
    "github_*": "allow",
    "searxng_*": "allow"
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 16384
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.homelab.leehosanganson.dev",
        "apiKey": "{file:~/.config/sops-nix/secrets/litellm-api-key}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 16384
          }
        },
        "gemini/gemini-2.5-flash-lite": {},
        "gemini/gemini-3.1-pro": {},
        "openrouter/openrouter/free": {}
      }
    },
    "github-copilot": {
      "name": "GitHub Copilot"
    }
  },
  "mcp": {
    "github": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:~/.config/sops-nix/secrets/opencode-github-pat}"
      }
    },
    "searxng": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "mcp-searxng"],
      "environment": {
        "SEARXNG_URL": "https://searxng.homelab.leehosanganson.dev"
      }
    }
  },
  "plugin": ["@slkiser/opencode-quota"]
}
