{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "general",
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    },
    "build": {
      "permission": {
        "skill": {
          "*": "allow"
        }
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "provider": {
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM",
      "options": {
        "baseURL": "https://litellm.homelab.leehosanganson.dev",
        "apiKey": "{file:~/.config/sops-nix/secrets/litellm-api-key}"
      },
      "models": {
        "unsloth/qwen-3.6": {
          "limit": {
            "context": 131072,
            "output": 8192
          }
        },
        "gemini/gemini-2.5-flash-lite": {},
        "gemini/gemini-2.5-flash": {},
        "gemini/gemini-2.5-pro": {},
        "gemini/gemini-3-flash-preview": {}
      }
    },
    "github-copilot": {
      "name": "GitHub Copilot"
    }
  },
  "mcp": {
    "github": {
      "enabled": false,
      "type": "remote",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer {file:~/.config/sops-nix/secrets/opencode-github-pat}"
      }
    }
  },
  "plugin": ["@slkiser/opencode-quota"]
}
