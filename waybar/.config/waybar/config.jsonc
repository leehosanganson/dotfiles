[
  {
    "layer": "top",
    "height": 30,
    "position": "top",
    "spacing" : 0, 
    "include": ["$HOME/.config/waybar/modules.jsonc"],
    
    "modules-left": [
      "hyprland/workspaces",
      "cpu",
      "memory",
    ],

    "modules-center": [
      "clock",
    ],

    "modules-right": [
      "custom/cava",
      "bluetooth",
      "network",
      "pulseaudio", 
    ],
  }
]
